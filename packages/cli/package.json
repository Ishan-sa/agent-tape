{
  "name": "@agenttape/cli",
  "version": "0.4.1",
  "description": "AgentTape CLI",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agenttape": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@agenttape/core": "workspace:*",
    "@agenttape/diff-engine": "workspace:*",
    "@agenttape/replay-engine": "workspace:*",
    "@agenttape/test-runner": "workspace:*",
    "commander": "^14.0.1"
  }
}
